# คัดลอกไฟล์นี้เป็น .env.production บนเซิร์ฟเวอร์ แล้วกรอกรหัสผ่านเอง
# (ไฟล์ .env.production ถูก gitignore — ไม่ถูก commit)

# ---- ค่าเชื่อมต่อของแอป (Next.js) ----
# ใช้ service db ใน docker-compose → DB_HOST=db
# ใช้ MySQL บนเครื่อง host → DB_HOST=host.docker.internal
DB_HOST=db
DB_PORT=3306
DB_NAME=newssra
DB_USER=newssra
DB_PASSWORD=

# ---- ค่าของ MySQL container (service db) — ให้ตรงกับด้านบน ----
MYSQL_DATABASE=newssra
MYSQL_USER=newssra
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
